generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          String   @id @default(cuid())
  title       String
  description String
  workType    WorkType
  location    String
  industry    String
  jobType     String
  status      JobStatus @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  applications Application[]
}

model Application {
  id            String   @id @default(cuid())
  jobId         String
  jobTitle      String
  jobLocation   String
  workType      String
  candidateName String
  email         String
  phone         String
  message       String?
  resumeUrl     String
  submittedAt   DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ResumeSubmission {
  id           String   @id @default(cuid())
  fullName     String
  email        String
  phone        String?
  desiredTitle String
  industry     String
  message      String?
  resumeUrl    String
  submittedAt  DateTime @default(now())
}

model EmployerRequest {
  id                String            @id @default(cuid())
  fullName          String
  companyName       String
  jobTitle          String
  email             String
  phone             String
  industry          String
  jobType           String
  numberOfPositions Int               @default(1)
  message           String?
  status            EmployerReqStatus @default(NEW)
  submittedAt       DateTime          @default(now())
}

enum WorkType {
  REMOTE
  WORK_FROM_OFFICE
  HYBRID
}

enum JobStatus {
  ACTIVE
  DRAFT
}

enum EmployerReqStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

